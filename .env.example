JWT_SECRET=please-change-me
JWT_EXPIRES_IN=1h

# Snowflake ID generator
# Must be unique per instance in multi-instance deployments (0-1023)
SNOWFLAKE_WORKER_ID=0

# Backwards-compatible alias (prefer SNOWFLAKE_WORKER_ID)
# SNOWFLAKE_MACHINE_ID=0
# Optional custom epoch (milliseconds)
# SNOWFLAKE_EPOCH=1597017600000
