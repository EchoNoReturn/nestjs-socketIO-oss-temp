<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .code { font-size: 24px; font-weight: bold; color: #2563eb; letter-spacing: 4px; }
    .footer { font-size: 12px; color: #666; margin-top: 20px; }
  </style>
</head>
<body>
  <div class="container">
    <p>Hello, your verification code is:</p>
    <p class="code">{{code}}</p>
    <p>This verification code is valid for <strong>{{expiresIn}}</strong> minutes. Please complete the verification promptly.</p>
    <div class="footer">
      <p>If this was not your action, please ignore this email.</p>
    </div>
  </div>
</body>
</html>
